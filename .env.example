NVIDIA_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
DOCKER_SANDBOX_IMAGE=python:3.11-slim
SUPABASE_URL=
# Server-side only — bypasses RLS, backend enforces per-session
# ownership itself (api/routes.py). Never ship this to a browser.
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated. Defaults to localhost:3000,3001 if unset — override
# for any real deployment.
CORS_ALLOWED_ORIGINS=
# Frontend build-time only: baked into the client bundle, must point at
# the backend's public URL for a real deploy.
NEXT_PUBLIC_API_URL=
